# ==========================================
# TL;DRun Environment Variables
# ==========================================

# Frontend is now hard-locked to backend-only provider calls.
# Do not place LLM provider keys in Vite/browser env variables.

# Server-side provider keys (recommended for production)
# At least one server key is required when using backend API generation.
GEMINI_API_KEY=

# Fallback API Key - supports OpenRouter, OpenAI, Groq, Anthropic
# Prefix determines provider:
#   sk-or-...  → OpenRouter (recommended, cheapest)
#   sk-...     → OpenAI
#   sk-ant-... → Anthropic
#   gsk_...    → Groq
OTHER_API_KEY=

# Server security / ops controls
PORT=3000
MAX_PDF_SIZE_MB=25
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=30
JOB_TTL_MS=3600000
AUTH_REQUIRED=true
AUTH_TOKEN_TTL_SEC=28800
DEMO_DAILY_RUN_LIMIT=3
DEMO_DAILY_CHAT_LIMIT=20
DEMO_DAILY_WINDOW_MS=86400000
# Set true (or subnet rule) only when running behind a trusted reverse proxy
TRUST_PROXY=false
# Required in production (32+ random bytes recommended)
APP_AUTH_SECRET=
MAX_CONTEXT_CHARS=180000
PAPER_FETCH_TIMEOUT_MS=12000
FULLTEXT_RESOLVER_TIMEOUT_MS=12000
FULLTEXT_CACHE_TTL_MS=900000
UNPAYWALL_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

# Neon Postgres (optional but recommended)
DATABASE_URL=
